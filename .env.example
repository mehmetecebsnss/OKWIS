# Okwis AI - Environment Variables Template
# Bu dosyayı .env olarak kopyalayın ve gerçek değerlerinizi girin

# ============================================================================
# AI PROVIDER CONFIGURATION
# ============================================================================

# Ana AI provider seçimi: gemini, deepseek, claude
AI_PROVIDER=gemini

# Fallback (yedek) provider'lar aktif mi?
AI_FALLBACK_GEMINI=true
AI_FALLBACK_DEEPSEEK=true

# ============================================================================
# API KEYS (GİZLİ - ASLA PAYLAŞMAYIN!)
# ============================================================================

# DeepSeek API Key
# Nereden alınır: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your_deepseek_key_here

# Gemini API Keys (birden fazla key rate limit için)
# Nereden alınır: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy_your_gemini_key_1_here
GEMINI_API_KEY_2=AIzaSy_your_gemini_key_2_here
GEMINI_API_KEY_3=AIzaSy_your_gemini_key_3_here
GEMINI_API_KEY_4=AIzaSy_your_gemini_key_4_here
GEMINI_API_KEY_5=AIzaSy_your_gemini_key_5_here
GEMINI_API_KEY_6=AIzaSy_your_gemini_key_6_here
GEMINI_API_KEY_7=AIzaSy_your_gemini_key_7_here
GEMINI_API_KEY_8=AIzaSy_your_gemini_key_8_here

# Claude API Key (opsiyonel, premium plan için)
# Nereden alınır: https://console.anthropic.com/
CLAUDE_API_KEY=sk-ant-your_claude_key_here

# ============================================================================
# TELEGRAM BOT
# ============================================================================

# Telegram Bot Token
# Nereden alınır: @BotFather
TELEGRAM_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# ============================================================================
# EXTERNAL APIs
# ============================================================================

# OpenWeatherMap API Key (hava durumu için)
# Nereden alınır: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# Tavily API Key (web araması için)
# Nereden alınır: https://tavily.com/
TAVILY_API_KEY=tvly-your_tavily_key_here

# ElevenLabs API Key (ses sentezi için, opsiyonel)
# Nereden alınır: https://elevenlabs.io/
ELEVENLABS_API_KEY=sk_your_elevenlabs_key_here

# ============================================================================
# RSS FEED URLs
# ============================================================================

GEO_RSS_URL=https://feeds.reuters.com/reuters/worldNews
MACRO_RSS_URLS=https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.reuters.com/reuters/businessNews
GEO_RSS_URLS=https://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.reuters.com/reuters/worldNews

# ============================================================================
# BOT CONFIGURATION
# ============================================================================

# Günlük ücretsiz analiz limiti
ANALIZ_GUNLUK_LIMIT=1

# Admin kullanıcı ID'leri (virgülle ayrılmış)
ADMIN_USER_IDS=123456789

# ============================================================================
# VOICE CONFIGURATION
# ============================================================================

# Edge TTS ses seçimi (Türkçe)
EDGE_TTS_VOICE=tr-TR-AhmetNeural

# Whisper prompt (ses tanıma için)
WHISPER_PROMPT=Okwis, senin adın, portföy, kripto

# Whisper model (tiny, base, small, medium, large)
WHISPER_MODEL=medium

# ============================================================================
# NOTLAR
# ============================================================================

# 1. Bu dosyayı .env olarak kopyalayın:
#    cp .env.example .env

# 2. Gerçek API key'lerinizi girin

# 3. .env dosyasını ASLA GitHub'a commit ETMEYİN!
#    (.gitignore'da zaten var)

# 4. Production'da environment variables kullanın:
#    export GEMINI_API_KEY="..."

# 5. API key'leri düzenli olarak rotate edin (30 günde bir)
