# Kopyala: `.env` olarak kaydet ve değerleri doldur.
# Bu dosya repoda güvenli kalır; gerçek anahtarları buraya yazma.

TELEGRAM_TOKEN=
GEMINI_API_KEY=
# Aynı anda birden fazla Gemini anahtarı (kota bitince sırayla): isteğe bağlı
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# veya tek satır: GEMINI_API_KEYS=key1,key2,key3
#
#  
#GEMINI_API_KEY_3=üçüncü_anahtar
# Yapay zekâ motoru: gemini (varsayılan: önce tüm Gemini anahtarları) | deepseek (önce DeepSeek)
# AI_PROVIDER=gemini
# DEEPSEEK_API_KEY=
# Tüm Gemini anahtarları kotada kaldıysa DeepSeek dene (DEEPSEEK_API_KEY varsa varsayılan açık): true | false
# AI_FALLBACK_DEEPSEEK=true
# DeepSeek başarısız olursa Gemini anahtarlarına dön (AI_PROVIDER=deepseek iken): true | false
# AI_FALLBACK_GEMINI=true
# İsteğe bağlı: deepseek-chat (varsayılan), deepseek-reasoner
# DEEPSEEK_MODEL=deepseek-chat
# Günlük ücretsiz analiz limiti (varsayılan: 3)
# ANALIZ_GUNLUK_LIMIT=3
# Admin kullanıcı id listesi (virgülle): /pro_ver, /pro_iptal, /claude_ver, /claude_iptal, /odeme_kayit yetkisi
# ADMIN_USER_IDS=123456789,987654321

# ── Tavily Web Araması ────────────────────────────────────────────────────────
# RSS'in ötesinde canlı web araması. Anahtarı ekleyince tüm modlar otomatik zenginleşir.
# Ücretsiz tier: 1000 istek/ay — https://app.tavily.com
# TAVILY_API_KEY=tvly-...
# Claude planı kullanıcılarına Claude API ile analiz yapılır.
# Anahtarı ekleyince /claude_ver komutuyla kullanıcıya plan ata.
# CLAUDE_API_KEY=sk-ant-...
# İsteğe bağlı model seçimi (varsayılan: claude-3-5-sonnet-20241022)
# CLAUDE_MODEL=claude-3-5-sonnet-20241022

# Hava modu için zorunlu; mevsim bağlamında isteğe bağlı başkent özeti için de kullanılır
# OPENWEATHER_API_KEY=

# İsteğe bağlı — Makro RSS (varsayılan: Reuters business; değiştirmek için)
# MACRO_RSS_URL=https://feeds.reuters.com/reuters/businessNews
# Önerilen: birden fazla RSS kaynağı (öncelik sırasıyla, virgülle)
# MACRO_RSS_URLS=https://feeds.bbci.co.uk/news/business/rss.xml,https://feeds.reuters.com/reuters/businessNews

# İsteğe bağlı — Jeopolitik RSS (varsayılan: Reuters worldNews)
# GEO_RSS_URL=https://feeds.reuters.com/reuters/worldNews
# Önerilen: birden fazla jeopolitik RSS kaynağı (öncelik sırasıyla, virgülle)
# GEO_RSS_URLS=https://feeds.bbci.co.uk/news/world/rss.xml,https://feeds.reuters.com/reuters/worldNews
